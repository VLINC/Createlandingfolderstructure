rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    /* =========================
       HELPER FUNCTIONS
    ========================== */
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth != null &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isProvider() {
      return isAuthenticated() && 
             firestore.get(/databases/(default)/documents/providers/$(request.auth.uid)).data != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidSize() {
      return request.resource.size <= 5 * 1024 * 1024;
    }
    
    function isValidFileType() {
      return request.resource.contentType.matches('image/.*') ||
             request.resource.contentType == 'application/pdf';
    }

    /* =========================
       ✅ NEW: AFFORDABLE ACCESS DOCUMENTS
    ========================== */
    match /affordable-access/{userId}/{fileName} {
      // User can upload their own files
      allow write: if isOwner(userId) &&
                      isValidSize() &&
                      isValidFileType();
      
      // User can read their own files
      allow read: if isOwner(userId);
      
      // Admin can read all
      allow read: if isAdmin();
      
      // Admin can delete
      allow delete: if isAdmin();
    }

    /* =========================
       ✅ BEFORE/AFTER PHOTOS
    ========================== */
    match /before/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /after/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    /* =========================
       PROVIDER DOCUMENTS (Pro Access)
    ========================== */
    match /documents/{userId}/{fileName} {
      allow write: if isOwner(userId) && 
                      isValidSize() && 
                      isValidFileType();
      
      allow read: if isOwner(userId);
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }
    
    /* =========================
       PROFILE PHOTOS
    ========================== */
    match /profiles/{userId}/{fileName} {
      allow write: if isOwner(userId) && 
                      isValidSize() && 
                      request.resource.contentType.matches('image/.*');
      
      allow read: if isAuthenticated();
      allow delete: if isOwner(userId);
      allow delete: if isAdmin();
    }
    
    /* =========================
       VEHICLE PHOTOS
    ========================== */
    match /vehicles/{userId}/{fileName} {
      allow write: if isOwner(userId) && 
                      isValidSize() && 
                      request.resource.contentType.matches('image/.*');
      
      allow read: if isOwner(userId);
      allow read: if isAdmin();
      allow delete: if isOwner(userId);
      allow delete: if isAdmin();
    }
    
    /* =========================
       TAX DOCUMENTS
    ========================== */
    match /tax-documents/{userId}/{fileName} {
      allow write: if false;
      allow read: if isOwner(userId);
      allow read: if isAdmin();
    }
    
    /* =========================
       MILEAGE REPORTS
    ========================== */
    match /mileage-reports/{userId}/{fileName} {
      allow write: if isOwner(userId);
      allow read: if isOwner(userId);
      allow read: if isAdmin();
    }
    
    /* =========================
       JOB PHOTOS
    ========================== */
    match /job-photos/{jobId}/{fileName} {
      allow write: if isAuthenticated() && 
                      isValidSize() && 
                      request.resource.contentType.matches('image/.*');
      
      allow read: if isAuthenticated();
    }
    
    /* =========================
       PROVIDER FILES
    ========================== */
    match /providers/{providerId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == providerId ||
        isAdmin()
      );
    }
    
    /* =========================
       CUSTOMER FILES
    ========================== */
    match /customers/{customerId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == customerId ||
        isAdmin()
      );
    }
    
    /* =========================
       USER FILES
    ========================== */
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin()
      );
    }
    
    /* =========================
       BOOKING FILES
    ========================== */
    match /bookings/{bookingId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    /* =========================
       JOB ATTACHMENTS
    ========================== */
    match /jobs/{jobId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    /* =========================
       SUPPORT ATTACHMENTS
    ========================== */
    match /support/{ticketId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    /* =========================
       ADMIN ONLY FILES
    ========================== */
    match /admin/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    /* =========================
       ANALYTICS & REPORTS
    ========================== */
    match /reports/{allPaths=**} {
      allow read, write: if isAdmin();
    }
    
    match /analytics/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}